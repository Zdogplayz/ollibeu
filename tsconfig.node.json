{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "composite": true,
    "types": ["node"]
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*", "src/renderer/src/**/*", "tests/**/*", "electron.vite.config.ts", "vitest.config.ts"],
  "exclude": ["src/renderer/src/**/*.tsx", "src/renderer/src/**/*.jsx"]
}
